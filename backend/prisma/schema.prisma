generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VehicleStatus {
  AVAILABLE
  IN_SHOP
  ON_TRIP
  OUT_OF_SERVICE
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
}

enum TripStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

model OrganizationSettings {
  id               Int      @id @default(autoincrement())
  organizationName String   @db.VarChar(100)
  timezone         String   @default("UTC") @db.VarChar(50)
  currency         String   @default("USD") @db.VarChar(10)
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  updatedAt        DateTime @default(now()) @db.Timestamp(6)

  @@map("organization_settings")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String   @db.VarChar(100)
  details   String?  @db.Text
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @db.Timestamp(6)

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Permission {
  id              Int              @id @default(autoincrement())
  name            String           @unique @db.VarChar(100)
  description     String?          @db.VarChar(255)
  createdAt       DateTime         @default(now()) @db.Timestamp(6)
  updatedAt       DateTime         @default(now()) @db.Timestamp(6)
  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique @db.VarChar(50)
  description     String?          @db.VarChar(255)
  createdAt       DateTime         @default(now()) @db.Timestamp(6)
  updatedAt       DateTime         @default(now()) @db.Timestamp(6)
  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  createdAt    DateTime   @default(now()) @db.Timestamp(6)
  updatedAt    DateTime   @default(now()) @db.Timestamp(6)

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id               Int               @id @default(autoincrement())
  name             String            @db.VarChar(100)
  email            String            @unique @db.VarChar(150)
  passwordHash     String            @db.VarChar(255)
  roleId           Int?
  isActive         Boolean           @default(false)
  emailVerified    Boolean           @default(false)
  createdAt        DateTime          @default(now()) @db.Timestamp(6)
  updatedAt        DateTime          @default(now()) @db.Timestamp(6)

  role             Role?             @relation(fields: [roleId], references: [id], onDelete: Restrict)
  otpVerifications OtpVerification[]
  tripsCreated     Trip[]
  auditLogs        AuditLog[]
  driver           Driver?

  @@index([email])
  @@map("users")
}

model OtpVerification {
  id        Int      @id @default(autoincrement())
  userId    Int
  otpHash   String   @db.VarChar(255)
  purpose   String   @default("LOGIN") @db.VarChar(20)
  expiresAt DateTime @db.Timestamp(6)
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @db.Timestamp(6)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("otp_verifications")
}

model Region {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(50)
  centerLat Decimal?   @db.Decimal(9, 6)
  centerLng Decimal?   @db.Decimal(9, 6)
  createdAt DateTime   @default(now()) @db.Timestamp(6)
  updatedAt DateTime   @default(now()) @db.Timestamp(6)

  drivers   Driver[]
  trips     Trip[]
  vehicles  Vehicle[]

  @@map("regions")
}

model Vehicle {
  id                 Int                 @id @default(autoincrement())
  registrationNumber String              @unique @db.VarChar(50)
  nameModel          String              @db.VarChar(100)
  type               String?             @db.VarChar(50)
  maxLoadCapacity    Decimal             @db.Decimal(10, 2)
  odometer           Decimal             @default(0) @db.Decimal(10, 2)
  acquisitionCost    Decimal             @db.Decimal(12, 2)
  status             VehicleStatus       @default(AVAILABLE)
  regionId           Int?
  currentLat         Decimal?            @db.Decimal(9, 6)
  currentLng         Decimal?            @db.Decimal(9, 6)
  createdAt          DateTime            @default(now()) @db.Timestamp(6)
  updatedAt          DateTime            @default(now()) @db.Timestamp(6)

  region             Region?             @relation(fields: [regionId], references: [id], onDelete: Restrict)
  expenses           Expense[]
  fuelLogs           FuelLog[]
  maintenanceRecords MaintenanceRecord[]
  trips              Trip[]

  @@index([status])
  @@index([regionId])
  @@map("vehicles")
}

model Driver {
  id                Int          @id @default(autoincrement())
  userId            Int          @unique
  licenseNumber     String       @unique @db.VarChar(50)
  licenseCategory   String?      @db.VarChar(20)
  licenseExpiryDate DateTime?    @db.Date
  contactNumber     String?      @db.VarChar(20)
  safetyScore       Decimal      @default(100.0) @db.Decimal(4, 1)
  status            DriverStatus @default(AVAILABLE)
  regionId          Int?
  createdAt         DateTime     @default(now()) @db.Timestamp(6)
  updatedAt         DateTime     @default(now()) @db.Timestamp(6)

  user              User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  region            Region?      @relation(fields: [regionId], references: [id], onDelete: Restrict)
  trips             Trip[]
  fuelLogs          FuelLog[]
  expenses          Expense[]

  @@index([status])
  @@map("drivers")
}

model Trip {
  id               Int        @id @default(autoincrement())
  source           String     @db.VarChar(150)
  destination      String     @db.VarChar(150)
  sourceLat        Decimal?   @db.Decimal(9, 6)
  sourceLng        Decimal?   @db.Decimal(9, 6)
  destLat          Decimal?   @db.Decimal(9, 6)
  destLng          Decimal?   @db.Decimal(9, 6)
  regionId         Int?
  vehicleId        Int
  driverId         Int
  cargoWeight      Decimal    @db.Decimal(10, 2)
  plannedDistance  Decimal    @db.Decimal(10, 2)
  actualDistance   Decimal?   @db.Decimal(10, 2)
  fuelConsumed     Decimal?   @db.Decimal(10, 2)
  revenue          Decimal?   @db.Decimal(12, 2)
  status           TripStatus @default(DRAFT)
  dispatchedAt     DateTime?  @db.Timestamp(6)
  completedAt      DateTime?  @db.Timestamp(6)
  createdBy        Int?
  createdAt        DateTime   @default(now()) @db.Timestamp(6)
  updatedAt        DateTime   @default(now()) @db.Timestamp(6)

  user             User?      @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  driver           Driver     @relation(fields: [driverId], references: [id], onDelete: Restrict)
  region           Region?    @relation(fields: [regionId], references: [id], onDelete: Restrict)
  vehicle          Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  fuelLogs         FuelLog[]

  @@index([status])
  @@index([driverId])
  @@map("trips")
}

model MaintenanceRecord {
  id          Int               @id @default(autoincrement())
  vehicleId   Int
  description String            @db.VarChar(255)
  cost        Decimal           @default(0) @db.Decimal(10, 2)
  status      MaintenanceStatus @default(ACTIVE)
  startedAt   DateTime          @default(dbgenerated("CURRENT_DATE")) @db.Date
  closedAt    DateTime?         @db.Date
  createdAt   DateTime          @default(now()) @db.Timestamp(6)
  updatedAt   DateTime          @default(now()) @db.Timestamp(6)

  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("maintenance_records")
}

model FuelLog {
  id           Int      @id @default(autoincrement())
  vehicleId    Int
  tripId       Int?
  driverId     Int?
  fuelQuantity Decimal  @db.Decimal(10, 2)
  cost         Decimal  @db.Decimal(10, 2)
  odometer     Decimal? @db.Decimal(10, 2)
  loggedAt     DateTime @default(now()) @db.Timestamp(6)
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @db.Timestamp(6)

  trip         Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver       Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@map("fuel_logs")
}

model Expense {
  id          Int      @id @default(autoincrement())
  vehicleId   Int
  driverId    Int?
  category    String   @db.VarChar(50)
  amount      Decimal  @db.Decimal(10, 2)
  description String?  @db.VarChar(255)
  incurredAt  DateTime @default(now()) @db.Timestamp(6)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @db.Timestamp(6)

  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver      Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@map("expenses")
}
