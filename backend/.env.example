# =============================================================================
# TransitOps Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before starting the server.
# NEVER commit .env — it is listed in .gitignore.
# Every variable declared here is validated by src/config/env.ts at startup.
# The server WILL NOT start if any required variable is missing or malformed.
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=5000
NODE_ENV=development
# Allowed values: development | test | production

# ---------------------------------------------------------------------------
# Database (Prisma connection string)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/transitops

# ---------------------------------------------------------------------------
# Auth — JWT tokens (access + refresh pattern)
# ---------------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins. Example: http://localhost:3000,https://transitops.app
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Bcrypt
# ---------------------------------------------------------------------------
BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Allowed values: combined | common | dev | short | tiny
LOG_FORMAT=dev

# ---- SMTP ----
SMTP_USER=
SMTP_PASS=
